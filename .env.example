# =============================================
# SurfCoach AI - 환경변수 설정
# 복사 후 .env 로 이름 변경하여 사용
# =============================================

# LLM 모델 선택 (claude / gpt4o / gemini / gemma4)
# 개발 시: claude 또는 gpt4o 권장
# 배포 시: gemma4 고정
LLM_PROVIDER=claude

# --- LLM API 키 (사용할 모델만 입력) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# Gemma4 로컬 설정 (배포 전용)
GEMMA4_MODEL_PATH=./models/gemma4

# --- 서버 설정 ---
HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- DB 설정 ---
DATABASE_URL=sqlite+aiosqlite:///./surfcoach.db

# --- 파일 업로드 ---
UPLOAD_DIR=./uploads
MAX_VIDEO_SIZE_MB=100
